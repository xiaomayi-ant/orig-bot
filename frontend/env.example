# ------------------------------
# Frontend Environment Template
# ------------------------------

# ===== Database (Prisma) =====
# Must point to the same PostgreSQL instance as Prisma migrations.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chat_history?schema=public

# ===== Backend API =====
# Server-side proxy target used by Next API routes.
LANGGRAPH_API_URL=http://localhost:3001/api
LANGCHAIN_API_KEY=
NEXT_BASE_PATH=/smart-bot

# Public runtime URL (for browser-side calls/fallbacks)
NEXT_PUBLIC_BASE_PATH=/smart-bot
NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:3000/smart-bot/api
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000/smart-bot
NEXT_PUBLIC_DEBUG_STREAM=false

# ===== Auth =====
# Keep this consistent with backend JWT_SECRET.
JWT_SECRET=change-this-to-a-long-random-secret

# ===== Optional: OSS file storage =====
ALI_OSS_REGION=
ALI_OSS_ACCESS_KEY_ID=
ALI_OSS_ACCESS_KEY_SECRET=
ALI_OSS_BUCKET=
ALI_OSS_PUBLIC_ENDPOINT=
ALI_OSS_PREFIX=audio/

# ===== Optional: ASR providers =====
GROQ_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/asr/transcription
DASHSCOPE_TASKS_URL=https://dashscope.aliyuncs.com/api/v1/tasks
DASHSCOPE_ASR_MODEL=paraformer-v2
QWEN_ASR_MODEL=paraformer-v2

# Optional when using OpenAI for transcription/token endpoints
OPENAI_API_KEY=
