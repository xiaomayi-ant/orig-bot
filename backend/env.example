# ------------------------------
# Backend Environment Template
# ------------------------------

# ===== LLM Provider =====
# Options: deepseek | openai
LLM_PROVIDER=deepseek
STRUCTURED_PLANNER_METHOD=auto

# DeepSeek (used when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible chat model (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Legacy key still read by parts of runtime
LLM_MODEL=gpt-4o-mini

# ===== Server =====
HOST=0.0.0.0
PORT=3001
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
TRACE_EVENTS=false
DEBUG_GRAPH_EVENTS=0
LOG_FULL_ASSISTANT_REPLY=1
INTENT_ENABLED=false

# ===== Auth =====
JWT_SECRET=change-this-to-a-long-random-secret

# ===== PostgreSQL (thread/checkpointer persistence, backend) =====
PG_DSN=postgresql://postgres:postgres@localhost:5432/chat_history?sslmode=disable

# ===== MySQL (SQL tool) =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ===== Milvus (vector/document search) =====
MILVUS_ADDRESS=localhost:19530
MILVUS_SSL=false

# Embeddings (OpenAI-compatible)
OPENAI_EMBED_API_KEY=
OPENAI_EMBED_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIM=1536

# Vector options
DOCUMENTS_COLLECTION_NAME=documents
RESET_DOCUMENTS_COLLECTION_ON_STARTUP=false

# ===== Neo4j / Graphiti =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ===== Web Search =====
TAVILY_API_KEY=

# ===== Voice / ASR =====
ENABLE_VOICE=true
WHISPER_MODEL=base
ASR_LANGUAGE=

# ===== Vision =====
ENABLE_VISION=true
VISION_MAX_IMAGE_SIZE=20

# ===== RAG =====
RAG_ATTEMPTS_MAX=1
RAG_TOP_K_FAST=6
RAG_TOP_K_PRECISE=20
RAG_MMR_LAMBDA=0.3
RAG_MIN_SCORE=0.5
RAG_MIN_MARGIN=0.05
RAG_MIN_AVG=0.45
RAG_ENABLE_RERANK=false
RAG_SOURCES_DEFAULT=["vector"]
